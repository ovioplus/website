# ─── Email delivery (Resend) ─────────────────────────────────────────────
# Get an API key at https://resend.com → free tier: 3,000 emails / month
# Without this key, contact form submissions log to the terminal only.
# IMPORTANT: copy this file to .env.local and put your real key there.
# Never commit real secrets to .env.example (it is tracked in git).
RESEND_API_KEY=
# Inbox where demo requests land
CONTACT_TO=ayoub.balti@ovioplus.com

# Sender address. MUST use a domain you have verified in Resend.
# Use Resend's default until ovioplus.com is verified:
#   CONTACT_FROM=OvioPlus <onboarding@resend.dev>
# Once ovioplus.com is verified in Resend, switch to:
#   CONTACT_FROM=OvioPlus <noreply@ovioplus.com>
CONTACT_FROM=OvioPlus <onboarding@resend.dev>
